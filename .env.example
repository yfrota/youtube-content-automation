# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# YouTube (Google API)
YOUTUBE_API_KEY=your_key_here
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/callback/youtube

# AI / LLM Provider
# OpenRouter replaces direct Anthropic and OpenAI SDK usage for agents
# (lib/agents/) — one gateway, model selectable per call (default:
# google/gemini-2.5-flash). ANTHROPIC_API_KEY/OPENAI_API_KEY are no longer used.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Used directly (not via OpenRouter) for RAG embeddings (lib/rag/embeddings.ts)
# — Gemini gemini-embedding-001, 768 dims.
GEMINI_API_KEY=your_gemini_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only — stands in for the authenticated user's client_id until
# Supabase Auth + tenant membership exists (see docs/rls-policies.md).
# GET /api/projects reads this directly; remove once real auth lands.
DEV_CLIENT_ID=00000000-0000-0000-0000-000000000000
